# Local development: auth is disabled by default.
# Just copy this file to .dev.vars and run `make dev`.
# This file is gitignored and never deployed.
DISABLE_AUTH=true

# To test with real GitHub OAuth locally, remove DISABLE_AUTH above
# and uncomment the three lines below. Create an OAuth App at:
# https://github.com/settings/developers
# Set Callback URL to: http://localhost:8787/api/auth/callback
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret
# ALLOWED_EMAILS=your@email.com

# Browser Rendering (optional — enables JS-heavy page screenshots)
# CF_ACCOUNT_ID=your_account_id
# CF_API_TOKEN=your_api_token
