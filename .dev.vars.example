# Local development secrets.
# Copy this file to .dev.vars and run `make dev` (which adds DISABLE_AUTH automatically).
# This file is gitignored and never deployed.

# GitHub OAuth credentials (required for production, optional for local dev)
# Create at https://github.com/settings/developers
# Set Callback URL to: http://localhost:8787/api/auth/callback
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret
# ALLOWED_EMAILS=your@email.com
